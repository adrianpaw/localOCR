# Flask configuration
FLASK_APP=web.py
FLASK_ENV=production
FLASK_DEBUG=0

# Server configuration
PORT=5000
HOST=0.0.0.0

# OCR configuration
OCR_LANGUAGES=en,ru
OCR_GPU=true

# Upload settings
MAX_CONTENT_LENGTH_MB=50
UPLOAD_FOLDER=uploads

# Optional: EasyOCR model download path (leave empty for default)
EASYOCR_MODEL_PATH=

# Note: In production, set actual values in the hosting platform's environment variables.